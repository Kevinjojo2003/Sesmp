# ── API Keys ──
GEMINI_API_KEY=
NEWS_API_KEY=

# Reddit (optional – for Reddit sentiment)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock_sentiment_bot/1.0

# ── Paths ──
MODEL_DIR=models
DATA_DIR=data

# ── Model / Runtime Defaults ──
LSTM_SEQUENCE_LENGTH=60
NEWS_PAGE_SIZE=10
DEFAULT_TICKER=AAPL

# ── Gemini Model (update when new versions release) ──
GEMINI_MODEL=models/gemini-1.5-pro
